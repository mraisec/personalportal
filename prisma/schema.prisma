// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects         Project[]
  gmailAccounts    GmailAccount[]
  drives           Drive[]
  transactions     Transaction[]
  music            Music[]
  watchlistItems   WatchlistItem[]
  habits           Habit[]
  homeProjects     HomeProject[]
  honeyDoItems     HoneyDoItem[]

  @@map("users")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("projects")
}

model GmailAccount {
  id          String   @id @default(cuid())
  email       String
  accessToken String?
  refreshToken String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("gmail_accounts")
}

model Drive {
  id          String   @id @default(cuid())
  name        String
  type        String
  path        String
  size        BigInt?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("drives")
}

model Transaction {
  id          String   @id @default(cuid())
  amount      Float
  type        String
  category    String
  description String?
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Music {
  id          String   @id @default(cuid())
  title       String
  artist      String
  album       String?
  genre       String?
  isTop10     Boolean  @default(false)
  month       String
  year        Int
  playCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("music")
}

model WatchlistItem {
  id          String   @id @default(cuid())
  title       String
  type        String
  status      String   @default("to_watch")
  rating      Int?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("watchlist_items")
}

model Habit {
  id          String   @id @default(cuid())
  name        String
  description String?
  frequency   String
  targetCount Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackings  HabitTracking[]

  @@map("habits")
}

model HabitTracking {
  id        String   @id @default(cuid())
  habitId   String
  date      DateTime
  completed Boolean  @default(false)
  count     Int?
  createdAt DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@map("habit_trackings")
}

model HomeProject {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("planning")
  priority    String   @default("medium")
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("home_projects")
}

model HoneyDoItem {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("pending")
  priority    String   @default("medium")
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("honey_do_items")
}
